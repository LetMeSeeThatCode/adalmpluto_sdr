- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport pmt\nfrom gnuradio import gr\n\nclass\
      \ adsb_extractor(gr.sync_block):\n    def __init__(self):\n        gr.sync_block.__init__(self,\n\
      \            name=\"ADSB Bit Extractor\",\n            in_sig=[np.dtype(np.uint8)],\n\
      \            out_sig=[np.dtype(np.uint8)])\n        self.capturing = False\n\
      \        self.buffer = []\n\n    def work(self, input_items, output_items):\n\
      \        in0 = input_items[0]\n        out = output_items[0]\n        \n   \
      \     # Check for tags in the current window\n        tags = self.get_tags_in_range(0,\
      \ 0, len(in0))\n        for tag in tags:\n            if tag.key == pmt.intern(\"\
      preamble\"):\n                self.capturing = True\n                self.buffer\
      \ = []\n\n        # Process samples\n        for i, val in enumerate(in0):\n\
      \            if self.capturing:\n                self.buffer.append(val)\n \
      \               if len(self.buffer) == 112:  # ADS-B message length\n      \
      \              bits_str = ''.join(str(int(b)) for b in self.buffer)\n      \
      \              print(f\"ADS-B: {bits_str}\")\n                    self.capturing\
      \ = False\n                    self.buffer = []\n            out[i] = val\n\n\
      \        return len(out)"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
